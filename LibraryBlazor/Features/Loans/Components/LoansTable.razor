@using LibraryBlazor.Features.Loans.Models

<div class="table-card">
    <div class="d-flex justify-content-between align-items-center p-2 border-bottom bg-white">
        @* <div class="btn-toolbar gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OnEdit" disabled="@(!CanEdit)">
                <i class="bi bi-pencil"></i> Edit Book
            </button>
            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="OnDelete" disabled="@(!CanDelete)">
                <i class="bi bi-trash"></i> Delete Book(s)
            </button>
        </div>
        <div>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OnNew">
                <i class="bi bi-plus"></i> New Book
            </button>
        </div> *@
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th><input type="checkbox" @bind="SelectAllRows" /></th>
                    <th>Id</th>
                    <th>BookId</th>
                    <th>Loan Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                </tr>
                <tr class="filters">
                    <th></th>
                    <th><input class="form-control form-control-sm" placeholder="Filter Id" value="@FilterId" @oninput="OnFilterIdInput" /></th>
                    <th><input class="form-control form-control-sm" placeholder="Filter BookId" value="@FilterTitle" @oninput="OnFilterTitleInput" /></th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in PagedItems)
                {
                    <tr class="@GetRowClass(loan)">
                        <td><input type="checkbox" @bind="loan.IsSelected" /></td>
                        <td>@loan.Id</td>
                        <td>@loan.BookCopyId</td>
                        <td>@loan.LoanDate</td>
                        <td>@loan.DueDate</td>
                        <td>@FormatStatus(loan.Status)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="border-top d-flex flex-wrap gap-2 align-items-center justify-content-between p-2">
        <div class="text-muted small">@($"{FilteredItems.Count()} of {Items.Count} items")</div>

        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="text-muted small mb-0">Items per page</label>
            <select class="form-select form-select-sm" style="width: 80px" @onchange="OnPageSizeChanged">
                @foreach (var size in new[] { 5, 10, 20, 50 })
                {
                    <option value="@size" selected="@(size == PageSize)">@size</option>
                }
            </select>

            <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(CurrentPage <= 1)">‹</button>
                <span class="small fw-semibold">@CurrentPage / @TotalPages</span>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
            </div>
        </div>
    </div>
</div>