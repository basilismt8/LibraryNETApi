@using LibraryBlazor.Features.Books.Models
@using LibraryBlazor.Components

<div class="table-card">
    <div class="d-flex justify-content-between align-items-center p-2">
        <AuthorizeView Roles="Librarian">
            <div class="btn-toolbar gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OnEdit" disabled="@(!CanEdit)">
                    <i class="bi bi-pencil"></i> Edit Book
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="OnDelete" disabled="@(!CanDelete)">
                    <i class="bi bi-trash"></i> Delete Book(s)
                </button>
            </div>
            <div class="btn-toolbar gap-2">

                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OnNew">
                    <i class="bi bi-plus"></i> New Book
                </button>
            </div>
        </AuthorizeView>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <AuthorizeView Roles="Librarian">
                        <th>Id</th>
                    </AuthorizeView>
                    <th>Title</th>
                    <th>Copies Available</th>
                    <th>Total Copies</th>
                    <th class="col-action">Loan</th>
                </tr>
                <tr class="filters">
                    <AuthorizeView Roles="Librarian">
                        <th><input class="form-control form-control-sm" placeholder="Filter Id" value="@FilterId" @oninput="OnFilterIdInput" /></th>
                    </AuthorizeView>
                    <th><input class="form-control form-control-sm" placeholder="Filter Title" value="@FilterTitle" @oninput="OnFilterTitleInput" /></th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in PagedItems)
                {
                    <tr class="@GetRowClass(book)" @onclick="() => ToggleSelection(book)">
                        <AuthorizeView Roles="Librarian">
                            <td><GuidDisplay Value="@book.Id" /></td>
                        </AuthorizeView>
                        <td>@book.Title</td>
                        <td>@book.CopiesAvailable</td>
                        <td>@book.TotalCopies</td>
                        <td class="action-cell">
                            <button type="button" class="btn btn-extend-loan" title="Loan book"
                                    @onclick="() => OnLoan.InvokeAsync(book)"
                                    @onclick:stopPropagation="true"
                                    disabled="@(book.CopiesAvailable <= 0)">
                                <i class="bi bi-book"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        <div class="d-flex align-items-center gap-2">
            <label class="text-muted small mb-0">Rows per page</label>
            <select class="form-select form-select-sm" style="width: 72px" @onchange="OnPageSizeChanged">
                @foreach (var size in new[] { 5, 10, 20, 50 })
                {
                    <option value="@size" selected="@(size == PageSize)">@size</option>
                }
            </select>
        </div>

        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="FirstPage" disabled="@(CurrentPage <= 1)">«</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(CurrentPage <= 1)">‹</button>
            <span class="page-current">@CurrentPage</span>
            <span class="page-separator">/ @TotalPages</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="LastPage" disabled="@(CurrentPage >= TotalPages)">»</button>
            <span class="total-records">Total Records: @FilteredItems.Count()</span>
        </div>
    </div>
</div>