@if (IsOpen)
{
    <div class="book-modal-overlay show" role="dialog" aria-modal="true" @onclick="HandleCancelAsync">
        <div class="book-modal" @onclick:stopPropagation>
            <div class="book-modal-header">
                <h3 class="book-modal-title">@Title</h3>
                <button type="button" class="book-modal-close" aria-label="Close" @onclick="HandleCancelAsync" disabled="@Saving">×</button>
            </div>

            <div class="book-modal-body">
                @if (!string.IsNullOrWhiteSpace(Error))
                {
                    <div class="alert alert-danger" role="alert">@Error</div>
                }

                <div class="book-form-row">
                    <div class="book-form-group full">
                        <label>Title <span class="required-star" aria-hidden="true">*</span></label>
                        <input @bind="Model.Title" disabled="@Saving" />
                    </div>

                    <div class="book-form-group">
                        <label>Copies Available</label>
                        <input type="number" @bind="Model.CopiesAvailable" disabled="@Saving" />
                    </div>

                    <div class="book-form-group">
                        <label>Total Copies</label>
                        <input type="number" @bind="Model.TotalCopies" disabled="@Saving" />
                    </div>
                </div>
            </div>

            <div class="book-modal-footer">
                <button type="button" class="bm-btn bm-btn-secondary" @onclick="HandleCancelAsync" disabled="@Saving">Cancel</button>
                <button type="button" class="bm-btn bm-btn-primary" @onclick="OnSave" disabled="@Saving">
                    @(Saving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}