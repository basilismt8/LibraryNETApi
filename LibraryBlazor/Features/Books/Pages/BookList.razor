@using LibraryBlazor.Features.Books.Models
@using LibraryBlazor.Shared.Models
@page "/books"
@inject LibraryBlazor.Features.Books.Services.BookApi BookApi
<PageTitle>Books</PageTitle>

<div class="table-card">
    <!-- Toolbar -->
    @* <div class="d-flex"> *@
        <div class="d-flex justify-content-between align-items-center p-2 border-bottom bg-white">
            <div class="btn-toolbar gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="EditBook" disabled="@(!CanEdit)">
                    <i class="bi bi-pencil"></i> Edit
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DeleteBooks" disabled="@(!CanDelete)">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
            <div>
            <button type="button" class="btn btn-primary btn-sm" @onclick="AddBook">
                    <i class="bi bi-plus"></i> New
                </button>
            </div>
        </div>
    @* </div> *@

    <!-- Table -->
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th><input type="checkbox" @bind="SelectAllRows" /></th>
                    <th>Id</th>
                    <th>Title</th>
                    <th>Copies Available</th>
                    <th>Total Copies</th>
                </tr>
                <tr class="filters">
                    <th></th>
                    <th><input class="form-control form-control-sm" placeholder="Filter Id" @bind="FilterId" /></th>
                    <th><input class="form-control form-control-sm" placeholder="Filter Title" @bind="FilterTitle" /></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in PagedBooks)
                {
                    <tr class="@GetRowClass(book)">
                        <td><input type="checkbox" @bind="book.IsSelected" /></td>
                        <td>@book.Id</td>
                        <td>@book.Title</td>
                        <td>@book.CopiesAvailable</td>
                        <td>@book.TotalCopies</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer / Pagination -->
    <div class="border-top d-flex align-items-center justify-content-between p-2">
        <div id="tableStatus">@($"{FilteredBooks.Count()} of {Books.Count} items")</div>
        <div>
            <button id="prevPage" @onclick="PrevPage" disabled="@(CurrentPage <= 1)">‹</button>
            <span id="currentPageDisplay">@CurrentPage / @TotalPages</span>
            <button id="nextPage" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">›</button>
            <select id="pageSize" @bind="PageSize">
                @foreach (var size in new int[] { 5, 10, 20, 50 })
                {
                    <option value="@size">@size</option>
                }
            </select>
        </div>
    </div>
</div>

@if (_showModal)
{
    <div class="book-modal-overlay show" role="dialog" aria-modal="true" @onclick="CloseModal">
        <div class="book-modal" @onclick:stopPropagation>
            <div class="book-modal-header">
                <h3 class="book-modal-title">@(_editingId is null ? "Add New Book" : "Edit Book")</h3>
                <button type="button" class="book-modal-close" aria-label="Close" @onclick="CloseModal" disabled="@_saving">×</button>
            </div>

            <div class="book-modal-body">
                @if (!string.IsNullOrWhiteSpace(_modalError))
                {
                    <div class="alert alert-danger" role="alert">@_modalError</div>
                }

                <div class="book-form-row">
                    <div class="book-form-group full">
                        <label>Title</label>
                        <input @bind="_form.Title" disabled="@_saving" />
                    </div>

                    <div class="book-form-group">
                        <label>Copies Available</label>
                        <input type="number" @bind="_form.CopiesAvailable" disabled="@_saving" />
                    </div>

                    <div class="book-form-group">
                        <label>Total Copies</label>
                        <input type="number" @bind="_form.TotalCopies" disabled="@_saving" />
                    </div>
                </div>
            </div>

            <div class="book-modal-footer">
                <button type="button" class="bm-btn bm-btn-secondary" @onclick="CloseModal" disabled="@_saving">Cancel</button>
                <button type="button" class="bm-btn bm-btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @(_saving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BookWrapper> Books = new();
    private string FilterId = "";
    private string FilterTitle = "";
    private int CurrentPage = 1;
    private int PageSize = 10;

    private bool _showModal;
    private bool _saving;
    private string? _modalError;
    private Guid? _editingId;
    private BookEditModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        var books = await BookApi.GetBooksAsync();
        Books = (books ?? Array.Empty<BookDto>()).Select(b => new BookWrapper(b)).ToList();
    }

    private IEnumerable<BookWrapper> FilteredBooks =>
        Books.Where(b =>
            (string.IsNullOrWhiteSpace(FilterId) || b.Id.ToString().Contains(FilterId, StringComparison.OrdinalIgnoreCase))
            && (string.IsNullOrWhiteSpace(FilterTitle) || b.Title.Contains(FilterTitle, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<BookWrapper> PagedBooks =>
        FilteredBooks.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredBooks.Count() / (double)PageSize));

    private bool SelectAllRows
    {
        get => FilteredBooks.All(b => b.IsSelected);
        set
        {
            foreach (var b in FilteredBooks)
                b.IsSelected = value;
        }
    }

    private bool CanEdit => Books.Count(b => b.IsSelected) == 1;
    private bool CanDelete => Books.Any(b => b.IsSelected);

    private async Task EditBook()
    {
        var book = Books.FirstOrDefault(b => b.IsSelected);
        if (book != null)
        {
            _modalError = null;
            _editingId = book.Id;
            _form = new BookEditModel
            {
                Title = book.Title,
                CopiesAvailable = book.CopiesAvailable,
                TotalCopies = book.TotalCopies
            };

            _showModal = true;
        }
    }

    private async Task DeleteBooks()
    {
        var ids = Books.Where(b => b.IsSelected).Select(b => b.Id).ToList();
        if (ids.Count > 0)
        {
            foreach (var id in ids)
            {
                await BookApi.DeleteBookAsync(id);
            }
            Books.RemoveAll(b => ids.Contains(b.Id));
        }
    }

    private async Task AddBook()
    {
        _modalError = null;
        _editingId = null;
        _form = new BookEditModel();
        _showModal = true;
    }

    private void CloseModal()
    {
        if (_saving)
        {
            return;
        }

        _showModal = false;
        _modalError = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _modalError = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_form.Title))
            {
                _modalError = "Title is required.";
                return;
            }

            if (_form.CopiesAvailable < 0 || _form.TotalCopies < 0)
            {
                _modalError = "Copies values must be 0 or greater.";
                return;
            }

            if (_editingId is null)
            {
                await BookApi.CreateBookAsync(new CreateBookRequestDto(
                    _form.Title.Trim(),
                    _form.CopiesAvailable,
                    _form.TotalCopies));
            }
            else
            {
                await BookApi.UpdateBookAsync(_editingId.Value, new UpdateBookRequestDto(
                    _form.Title.Trim(),
                    _form.CopiesAvailable,
                    _form.TotalCopies));
            }

            _showModal = false;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void PrevPage()
    {
        if (CurrentPage > 1) CurrentPage--;
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages) CurrentPage++;
    }

    private string GetRowClass(BookWrapper book) => book.IsSelected ? "table-active" : "";

    // Wrapper to track selection
    class BookWrapper : Book
    {
        public BookWrapper(BookDto book)
        {
            Id = book.id;
            Title = book.title;
            CopiesAvailable = book.copiesAvailable;
            TotalCopies = book.totalCopies;
        }
        public bool IsSelected { get; set; } = false;
    }

    private sealed class BookEditModel
    {
        public string Title { get; set; } = string.Empty;
        public int CopiesAvailable { get; set; }
        public int TotalCopies { get; set; }
    }
}

