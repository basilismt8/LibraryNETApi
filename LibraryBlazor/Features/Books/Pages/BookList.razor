@page "/books"
@using LibraryBlazor.Features.Books.Models
@using LibraryBlazor.Features.Books.Components
@inject LibraryBlazor.Features.Books.Services.BookApi BookApi

<PageTitle>Books</PageTitle>

<BooksTable Items="Books"
            FilterId="@FilterId"
            FilterIdChanged="@(v => FilterId = v)"
            FilterTitle="@FilterTitle"
            FilterTitleChanged="@(v => FilterTitle = v)"
            CurrentPage="@CurrentPage"
            CurrentPageChanged="@(v => CurrentPage = v)"
            PageSize="@PageSize"
            PageSizeChanged="@(v => PageSize = v)"
            OnNew="OpenNew"
            OnEdit="OpenEdit"
            OnDelete="DeleteSelected" />

<AddEditBookModal IsOpen="@_showModal"
                  IsOpenChanged="@(v => _showModal = v)"
                  Saving="@_saving"
                  Error="@_modalError"
                  EditingId="@_editingId"
                  Model="@_form"
                  OnCancel="CloseModal"
                  OnSave="SaveAsync" />

@code {
    private List<BookRowVm> Books = new();

    private string FilterId = "";
    private string FilterTitle = "";
    private int CurrentPage = 1;
    private int PageSize = 10;

    private bool _showModal;
    private bool _saving;
    private string? _modalError;
    private Guid? _editingId;
    private BookEditModel _form = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var books = await BookApi.GetBooksAsync();
        Books = (books ?? Array.Empty<BookDto>())
            .Select(b => new BookRowVm(b))
            .ToList();
    }

    private Task OpenNew()
    {
        Console.WriteLine("Opening new book modal...");
        _modalError = null;
        _editingId = null;
        _form = new BookEditModel();
        _showModal = true;
        return Task.CompletedTask;
    }

    private Task OpenEdit()
    {
        var book = Books.FirstOrDefault(b => b.IsSelected);
        if (book is null) return Task.CompletedTask;

        _modalError = null;
        _editingId = book.Id;
        _form = new BookEditModel
        {
            Title = book.Title,
            CopiesAvailable = book.CopiesAvailable,
            TotalCopies = book.TotalCopies
        };
        _showModal = true;
        return Task.CompletedTask;
    }

    private async Task DeleteSelected()
    {
        var ids = Books.Where(b => b.IsSelected).Select(b => b.Id).ToList();
        foreach (var id in ids)
        {
            await BookApi.DeleteBookAsync(id);
        }

        Books.RemoveAll(b => ids.Contains(b.Id));
    }

    private void CloseModal()
    {
        if (_saving) return;
        _showModal = false;
        _modalError = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _modalError = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_form.Title))
            {
                _modalError = "Title is required.";
                _saving = false;
                StateHasChanged();
                return;
            }

            if (_editingId is null)
            {
                await BookApi.CreateBookAsync(new CreateBookRequestDto(
                    _form.Title.Trim(),
                    _form.CopiesAvailable,
                    _form.TotalCopies));
            }
            else
            {
                await BookApi.UpdateBookAsync(_editingId.Value, new UpdateBookRequestDto(
                    _form.Title.Trim(),
                    _form.CopiesAvailable,
                    _form.TotalCopies));
            }

            _showModal = false;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
            StateHasChanged();
        }
        finally
        {
            _saving = false;
        }
    }
}
