@page "/books"
@using LibraryBlazor.Features.Books.Models
@using LibraryBlazor.Features.Books.Components
@using LibraryBlazor.Http
@inject LibraryBlazor.Features.Books.Services.BookApi BookApi

<PageTitle>Books</PageTitle>

<BooksTable Items="Books"
            FilterId="@FilterId"
            FilterIdChanged="@(v => FilterId = v)"
            FilterTitle="@FilterTitle"
            FilterTitleChanged="@(v => FilterTitle = v)"
            CurrentPage="@CurrentPage"
            CurrentPageChanged="@(v => CurrentPage = v)"
            PageSize="@PageSize"
            PageSizeChanged="@(v => PageSize = v)"
            OnNew="OpenNew"
            OnEdit="OpenEdit"
            OnLoan="OpenLoan"
            OnDelete="OpenDelete" />

<AddEditBookModal IsOpen="@_showModal"
                  IsOpenChanged="@(v => _showModal = v)"
                  Saving="@_saving"
                  Error="@_modalError"
                  EditingId="@_editingId"
                  Model="@_form"
                  OnCancel="CloseModal"
                  OnSave="SaveAsync" />

<ConfirmationModal IsOpen="@_showDeleteModal"
                   IsOpenChanged="@(v => _showDeleteModal = v)"
                   Title="@ConfirmTitle"
                   Message="@ConfirmMessage"
                   IsWarning="@ConfirmIsWarning"
                   CancelText="Cancel"
                   ConfirmText="@ConfirmButtonText"
                   OnCancel="CloseDeleteModal"
                   OnConfirm="ConfirmAsync" />

@code {
    private List<BookRowVm> Books = new();

    private string FilterId = "";
    private string FilterTitle = "";
    private int CurrentPage = 1;
    private int PageSize = 10;
    private int _numberOfSelectedBooks = 0;

    private bool _showModal;
    private bool _showDeleteModal;
    private bool _saving;
    private string? _modalError;
    private Guid? _editingId;
    private BookEditModel _form = new();

    private ConfirmAction _confirmAction;
    private string? _unavailableMessage;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var result = await BookApi.GetBooksAsync();
        if (!result.Success)
        {
            Books = new();
            _modalError = result.Message;
            return;
        }

        Books = (result.Data ?? Array.Empty<BookDto>())
            .Select(b => new BookRowVm(b))
            .ToList();
    }

    private Task OpenNew()
    {
        Console.WriteLine("Opening new book modal...");
        _modalError = null;
        _editingId = null;
        _form = new BookEditModel();
        _showModal = true;
        return Task.CompletedTask;
    }

    private Task OpenEdit()
    {
        var book = Books.FirstOrDefault(b => b.IsSelected);
        if (book is null) return Task.CompletedTask;

        _modalError = null;
        _editingId = book.Id;
        _form = new BookEditModel
        {
            Title = book.Title,
            CopiesAvailable = book.CopiesAvailable,
            TotalCopies = book.TotalCopies
        };
        _showModal = true;
        return Task.CompletedTask;
    }

    private Task OpenDelete()
    {
        var ids = Books.Where(b => b.IsSelected).Select(b => b.Id).ToList();
        _numberOfSelectedBooks = ids.Count;
        _confirmAction = ConfirmAction.Delete;
        _showDeleteModal = true;
        return Task.CompletedTask;
    }

    private Task OpenLoan()
    {
        var selectedBooks = Books.Where(b => b.IsSelected).ToList();
        _numberOfSelectedBooks = selectedBooks.Count;

        var unavailable = selectedBooks.Where(b => b.CopiesAvailable <= 0).ToList();
        if (unavailable.Any())
        {
            var names = string.Join(", ", unavailable.Select(b => $"\"{b.Title}\""));
            _unavailableMessage = unavailable.Count == 1
                ? $"The book {names} is not available for loan."
                : $"The following books are not available for loan: {names}.";
            _confirmAction = ConfirmAction.Info;
        }
        else
        {
            _unavailableMessage = null;
            _confirmAction = ConfirmAction.Loan;
        }

        _showDeleteModal = true;
        return Task.CompletedTask;
    }

    private string DeleteMessage => _numberOfSelectedBooks > 1
        ? "Are you sure that you want to delete these books?"
        : "Are you sure that you want to delete this book?";

    private string LoanMessage => _numberOfSelectedBooks > 1
    ? "Are you sure that you want to loan these books?"
    : "Are you sure that you want to loan this book?";

    private string ConfirmMessage => _confirmAction switch
    {
        ConfirmAction.Loan => LoanMessage,
        ConfirmAction.Info => _unavailableMessage ?? "",
        _ => DeleteMessage
    };

    private string ConfirmTitle => _confirmAction switch
    {
        ConfirmAction.Loan => "Loan confirmation",
        ConfirmAction.Info => "Loan unavailable",
        _ => "Delete confirmation"
    };

    private bool ConfirmIsWarning => _confirmAction is ConfirmAction.Delete or ConfirmAction.Info;

    private string ConfirmButtonText => _confirmAction == ConfirmAction.Info ? "OK" : "Yes";

    private Task ConfirmAsync() => _confirmAction switch
    {
        ConfirmAction.Loan => LoanSelected(),
        ConfirmAction.Info => CloseDeleteModalAsync(),
        _ => DeleteSelected()
    };

    private Task CloseDeleteModalAsync()
    {
        _showDeleteModal = false;
        return Task.CompletedTask;
    }

    private enum ConfirmAction
    {
        Delete,
        Loan,
        Info
    }

    private async Task DeleteSelected()
    {
        var ids = Books.Where(b => b.IsSelected).Select(b => b.Id).ToList();
        foreach (var id in ids)
        {
            var result = await BookApi.DeleteBookAsync(id);
            if (!result.Success)
            {
                _modalError = result.Message ?? "Failed to delete book.";
                return;
            }
        }
        _showDeleteModal = false;
        Books.RemoveAll(b => ids.Contains(b.Id));
    }

    private async Task LoanSelected()
    {
        var ids = Books.Where(b => b.IsSelected).Select(b => b.Id).ToList();

        var result = await BookApi.CreateLoanAsync(
            new CreateLoanRequestDto(
                 ids));
        if (!result.Success)
        {
            _modalError = result.Message ?? "Failed to delete book.";
            return;
        }
        _showDeleteModal = false;
    }

    private void CloseModal()
    {
        if (_saving) return;
        _showModal = false;
        _modalError = null;
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _modalError = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_form.Title))
            {
                _modalError = "Title is required.";
                return;
            }

            ApiResult result;

            if (_editingId is null)
            {
                result = await BookApi.CreateBookAsync(
                    new CreateBookRequestDto(
                        _form.Title.Trim(),
                        _form.CopiesAvailable,
                        _form.TotalCopies));
            }
            else
            {
                result = await BookApi.UpdateBookAsync(
                    _editingId.Value,
                    new UpdateBookRequestDto(
                        _form.Title.Trim(),
                        _form.CopiesAvailable,
                        _form.TotalCopies));
            }

            if (!result.Success)
            {
                if (result.ValidationErrors != null && result.ValidationErrors.Any())
                {
                    var messages = result.ValidationErrors
                        .SelectMany(e => e.Value)
                        .ToList();

                    _modalError = string.Join("\n", messages);
                }
                else
                {
                    _modalError = result.Message ?? "Unknown error";
                }

                return;
            }

            _showModal = false;
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
