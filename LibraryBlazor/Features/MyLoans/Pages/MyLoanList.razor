@page "/myloans"
@using LibraryBlazor.Features.MyLoans.Models
@using LibraryBlazor.Features.MyLoans.Components
@using LibraryBlazor.Shared.Models
@using LibraryBlazor.Http
@inject LibraryBlazor.Features.MyLoans.Services.MyLoansApi MyLoansApi

<PageTitle>My Loans</PageTitle>

<MyLoansTable Items="Loans"
            FilterId="@FilterId"
            FilterIdChanged="@(v => FilterId = v)"
            FilterTitle="@FilterTitle"
            FilterTitleChanged="@(v => FilterTitle = v)"
            CurrentPage="@CurrentPage"
            CurrentPageChanged="@(v => CurrentPage = v)"
            PageSize="@PageSize"
            PageSizeChanged="@(v => PageSize = v)"
            OnExtendLoan="OpenExtendLoan" />

<DueDateModal IsOpen="@_showModal"
                  IsOpenChanged="@(v => _showModal = v)"
                  Saving="@_saving"
                  Error="@_modalError"
                  Title="Extend Loan"
                  SubjectLabel="Book"
                  SubjectValue="@_selectedLoan?.BookTitle"
                  CurrentDueDate="@_selectedLoan?.DueDate"
                  DueDateLabel="New Due Date"
                  NewDueDate="@_newDueDate"
                  NewDueDateChanged="@((DateOnly v) => _newDueDate = v)"
                  OnCancel="CloseModal"
                  OnConfirm="SaveAsync" />

@code {
    private List<MyLoanRowVm> Loans = new();
    private bool _showModal;
    private bool _saving;
    private string FilterId = "";
    private MyLoanRowVm? _selectedLoan;
    private string FilterTitle = "";
    private int CurrentPage = 1;
    private int PageSize = 10;
    private int _numberOfSelectedLoans = 0;
    private DateOnly _newDueDate;
    private string? _modalError;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var result = await MyLoansApi.GetMyLoansAsync();
        if (!result.Success)
        {
            Loans = new();
            _modalError = result.Message;
            return;
        }

        Loans = (result.Data ?? Array.Empty<MyLoanDto>())
            .Select(b => new MyLoanRowVm(b))
            .ToList();
        Console.WriteLine($"My loans is {Loans}");

    }

    private Task OpenExtendLoan(MyLoanRowVm loan)
    {
        _selectedLoan = loan;
        _newDueDate = loan.DueDate;
        _modalError = null;
        _showModal = true;
        return Task.CompletedTask;
    }

    private void CloseModal()
    {
        if (_saving) return;
        _showModal = false;
        _modalError = null;
    }

    private async Task SaveAsync()
    {
        if (_selectedLoan is null) return;

        _saving = true;
        _modalError = null;

        try
        {

            if (string.IsNullOrWhiteSpace(_newDueDate.ToString()))
            {
                _modalError = "DueDate is required.";
                return;
            }

            ApiResult result;

            result = await MyLoansApi.ExtendLoanAsync(_selectedLoan.Id,
                    new ExtendLoanRequestDto(_newDueDate));

            
            if (!result.Success)
            {
                if (result.ValidationErrors != null && result.ValidationErrors.Any())
                {
                    var messages = result.ValidationErrors
                        .SelectMany(e => e.Value)
                        .ToList();

                    _modalError = string.Join("\n", messages);
                }
                else
                {
                    _modalError = result.Message ?? "Unknown error";
                }

                return;
            }

            _showModal = false;
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
