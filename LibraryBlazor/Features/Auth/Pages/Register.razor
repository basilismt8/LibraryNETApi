@page "/register"
@using LibraryBlazor.Features.Auth.Models
@layout LibraryBlazor.Layout.EmptyLayout

<PageTitle>Register</PageTitle>

<div class="login-page">
    <div class="login-bg">
        <div class="login-card" role="form" aria-label="Register form">
            <h2 class="login-title">Register</h2>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="login-error" role="alert">@_error</div>
            }

            <div class="login-field">
                <label>Email ID</label>
                <input type="email" @bind="Model.Email" placeholder="Email ID" />
            </div>

            <div class="login-field">
                <label>Password</label>
                <input type="password" @bind="Model.Password" placeholder="Password" />
            </div>

            <div class="login-field">
                <label>Confirm Password</label>
                <input type="password" @bind="Model.ConfirmPassword" placeholder="Confirm Password" />
            </div>

            <button type="button" class="login-button" @onclick="RegisterAsync">
                @(_saving ? "Registering..." : "Register")
            </button>

            <div class="login-footer">
                <span>Already have an account?</span>
                <NavLink class="login-link" href="login">Login</NavLink>
            </div>
        </div>
    </div>
</div>
