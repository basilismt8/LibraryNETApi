@inject LibraryBlazor.Auth.JwtAuthStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="sidebar-root @(_sidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar-brand">
        <div class="brand-mark">
            <i class="bi bi-book-half"></i>
        </div>
        <div class="brand-info">
            <span class="brand-name">Library</span>
            <span class="brand-sub">Management</span>
        </div>
        <button class="mobile-toggle" title="Navigation menu" @onclick="ToggleNavMenu">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <div class="sidebar-body @(collapseNavMenu ? "collapse" : "")">
        <div class="nav-group">
            <span class="nav-group-label">Menu</span>

            <div class="nav-item">
                <NavLink class="nav-pill" href="books" Match="NavLinkMatch.Prefix">
                    <span class="pill-icon"><i class="bi bi-book"></i></span>
                    <span class="pill-text">Books</span>
                </NavLink>
            </div>

            <AuthorizeView Roles="Librarian">
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-pill" href="loans" Match="NavLinkMatch.Prefix">
                            <span class="pill-icon"><i class="bi bi-clipboard-check"></i></span>
                            <span class="pill-text">Library Loans</span>
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-pill" href="myloans" Match="NavLinkMatch.Prefix">
                            <span class="pill-icon"><i class="bi bi-clipboard-check"></i></span>
                            <span class="pill-text">My Loans</span>
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="nav-spacer"></div>
        <div class="nav-divider"></div>

        <div class="nav-group nav-group-bottom">
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item">
                        <a class="nav-pill nav-pill-danger"
                           href=""
                           @onclick="OpenLogoutConfirm"
                           @onclick:preventDefault
                           @onclick:stopPropagation>
                            <span class="pill-icon"><i class="bi bi-box-arrow-left"></i></span>
                            <span class="pill-text">Logout</span>
                        </a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item">
                        <NavLink class="nav-pill" href="login">
                            <span class="pill-icon"><i class="bi bi-box-arrow-in-right"></i></span>
                            <span class="pill-text">Login</span>
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <button class="collapse-btn" @onclick="ToggleSidebar"
                title="@(_sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
            <i class="bi @(_sidebarCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
        </button>
    </div>
</div>

<ConfirmationModal IsOpen="@_showLogoutConfirm"
                   IsOpenChanged="@(v => _showLogoutConfirm = v)"
                   Title="Logout"
                   Message="Are you sure you want to logout?"
                   CancelText="Cancel"
                   ConfirmText="Logout"
                   OnConfirm="ConfirmLogoutAsync" />

@code {
    private bool collapseNavMenu = true;
    private bool _sidebarCollapsed;
    private bool _showLogoutConfirm;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private Task OpenLogoutConfirm()
    {
        _showLogoutConfirm = true;
        return Task.CompletedTask;
    }

    private async Task ConfirmLogoutAsync()
    {
        await AuthStateProvider.SignOutAsync();
        Nav.NavigateTo("/login", replace: true);
    }
}
