@if (IsOpen)
{
    <div class="book-modal-overlay show" role="dialog" aria-modal="true" @onclick="HandleCancelAsync">
        <div class="book-modal" @onclick:stopPropagation>
            <div class="book-modal-header">
                <h3 class="book-modal-title">@Title</h3>
            </div>

            <div class="book-modal-body">
                <div class="@MessageCssClass" role="alert">@Message</div>
            </div>

            <div class="book-modal-footer">
                <button type="button" class="bm-btn bm-btn-secondary" @onclick="HandleCancelAsync">@CancelText</button>
                <button type="button" class="bm-btn bm-btn-primary" @onclick="HandleConfirmAsync">@ConfirmText</button>
            </div>
        </div>
    </div>
}
