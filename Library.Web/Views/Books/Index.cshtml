@model IEnumerable<Library.Web.Models.DTO.BookDto>

@{
    ViewData["Title"] = "Books";
}

@section Styles {
    <link rel="stylesheet" href="~/css/books.css" asp-append-version="true" />
    <style>
        /* Modal overlay */
        .book-modal-overlay { position:fixed; inset:0; background:rgba(15,23,42,.55); backdrop-filter:blur(2px); display:none; z-index:1050; align-items:flex-start; justify-content:center; overflow:auto; padding:40px 20px; }
        .book-modal-overlay.show { display:flex; }
        .book-modal { background:#fff; border:1px solid #e2e8f0; border-radius:12px; width:100%; max-width:860px; box-shadow:0 10px 25px -5px rgba(0,0,0,0.18),0 8px 10px -6px rgba(0,0,0,0.12); position:relative; animation:scaleIn .15s ease; }
        @@keyframes scaleIn { from { transform:translateY(8px) scale(.98); opacity:0;} to { transform:translateY(0) scale(1); opacity:1;} }
        .book-modal-header { padding:22px 28px 8px; display:flex; justify-content:space-between; align-items:flex-start; }
        .book-modal-title { font-size:20px; font-weight:600; margin:0; color:#0f172a; }
        .book-modal-close { border:1px solid #e2e8f0; background:#fff; width:32px; height:32px; border-radius:6px; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; color:#475569; }
        .book-modal-close:hover { background:#f1f5f9; }
        .book-modal-body { padding:8px 28px 24px; }
        .book-form-row { display:flex; gap:24px; flex-wrap:wrap; }
        .book-form-group { flex:1 1 300px; display:flex; flex-direction:column; gap:6px; }
        .book-form-group.full { flex:1 1 100%; }
        .book-form-group label { font-size:12px; font-weight:600; text-transform:none; letter-spacing:.25px; color:#1e293b; }
        .book-form-group input, .book-form-group textarea { border:1px solid #d1d5db; background:#fff; border-radius:8px; padding:10px 12px; font-size:13px; line-height:1.3; resize:vertical; min-height:42px; }
        .book-form-group textarea { min-height:110px; }
        .book-form-group input:focus, .book-form-group textarea:focus { outline:none; box-shadow:0 0 0 2px rgba(30,144,255,0.18); }
        .book-modal-footer { padding:16px 28px 24px; display:flex; justify-content:flex-end; gap:12px; border-top:1px solid #f1f5f9; }
        .bm-btn { padding:10px 20px; font-size:14px; font-weight:500; border-radius:8px; border:1px solid transparent; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:background-color .15s, box-shadow .15s; }
        .bm-btn:focus-visible { outline:2px solid rgba(30,144,255,0.4); outline-offset:2px; }
        .bm-btn-secondary { background:#fff; border-color:#d1d5db; color:#1e293b; }
        .bm-btn-secondary:hover { background:#f1f5f9; }
        .bm-btn-primary { background:#1e293b; border-color:#1e293b; color:#fff; }
        .bm-btn-primary:hover { background:#334155; border-color:#334155; }
        @@media (max-width:720px){ .book-form-row { flex-direction:column; gap:12px;} .book-form-group { flex:1 1 auto;} }
    </style>
}

<h1 class="mt-3">Books</h1>

<div class="card table-card">
    <div class="d-flex justify-content-between align-items-center p-2 border-bottom bg-white">
        <div class="btn-toolbar gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnEdit" disabled>
                <i class="bi bi-pencil"></i> Edit
            </button>
            <button type="button" class="btn btn-outline-danger btn-sm" id="btnDelete" disabled>
                <i class="bi bi-trash"></i> Delete
            </button>
        </div>
        <div>
            <button type="button" class="btn btn-primary btn-sm" id="btnNew">
                <i class="bi bi-plus"></i> New
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0 align-middle" id="booksTable">
            <thead>
            <tr class="small text-uppercase text-muted bg-body-tertiary">
                <th style="width:30px;"><input type="checkbox" id="selectAll" /></th>
                <th>Id</th>
                <th>Title</th>
                <th>Copies Available</th>
                <th>Total Copies</th>
            </tr>
            <tr class="filters">
                <th></th>
                <th><input class="form-control form-control-sm" placeholder="Search Id" data-field="id" /></th>
                <th><input class="form-control form-control-sm" placeholder="Search Title" data-field="title" /></th>
                <th><input class="form-control form-control-sm" placeholder="Filter" data-field="copiesAvailable" /></th>
                <th><input class="form-control form-control-sm" placeholder="Filter" data-field="totalCopies" /></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var book in Model)
            {
                <tr data-id="@book.id" data-title="@book.title" data-copies-available="@book.copiesAvailable" data-total-copies="@book.totalCopies">
                    <td><input type="checkbox" class="row-select" /></td>
                    <td class="col-id">@book.id</td>
                    <td class="col-title">@book.title</td>
                    <td class="col-copiesAvailable">@book.copiesAvailable</td>
                    <td class="col-totalCopies">@book.totalCopies</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-3 py-1 small text-muted border-top gap-2 flex-wrap">
        <div id="tableStatus">@Model.Count() items total</div>
        <div class="d-flex align-items-center gap-2 ms-auto">
            <label class="mb-0 small text-muted">Items per page</label>
            <select id="pageSize" class="form-select form-select-sm" style="width:auto;">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary" id="prevPage" type="button">&lt;</button>
            <span id="currentPageDisplay" class="small" style="min-width:60px;text-align:center;">1 / 1</span>
            <button class="btn btn-sm btn-outline-secondary" id="nextPage" type="button">&gt;</button>
        </div>
    </div>
</div>

<!-- Modal (UI only) -->
<div class="book-modal-overlay" id="bookModal">
    <div class="book-modal" role="dialog" aria-modal="true" aria-labelledby="bookModalTitle">
        <div class="book-modal-header">
            <h2 class="book-modal-title" id="bookModalTitle">Add New Book</h2>
            <button type="button" class="book-modal-close" id="bookModalClose" aria-label="Close"><i class="bi bi-x"></i></button>
        </div>
        <div class="book-modal-body">
            <form id="bookForm" novalidate>
                <div class="book-form-row">
                    @* <div class="book-form-group">
                        <label for="bookId">Book Id</label>
                        <input id="bookId" name="bookId" placeholder="Auto / Guid" />
                    </div> *@
                    <div class="book-form-group">
                        <label for="bookTitle">Title</label>
                        <input id="bookTitle" name="title" placeholder="Enter title" />
                    </div>
                </div>
                <div class="book-form-row">
                    <div class="book-form-group">
                        <label for="copiesAvailable">Copies Available</label>
                        <input id="copiesAvailable" name="copiesAvailable" type="number" min="0" placeholder="0" />
                    </div>
                    <div class="book-form-group">
                        <label for="totalCopies">Total Copies</label>
                        <input id="totalCopies" name="totalCopies" type="number" min="0" placeholder="0" />
                    </div>
                </div>
                @* <div class="book-form-row">
                    <div class="book-form-group full">
                        <label for="notes">Notes</label>
                        <textarea id="notes" name="notes" placeholder="Add any notes..."></textarea>
                    </div>
                </div> *@
            </form>
        </div>
        <div class="book-modal-footer">
            <button type="button" class="bm-btn bm-btn-secondary" id="bookModalCancel">Cancel</button>
            <button type="button" class="bm-btn bm-btn-primary" id="bookModalSave">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/books.js" asp-append-version="true"></script>
    <script>
        (function(){
            const modal = document.getElementById('bookModal');
            const openNew = document.getElementById('btnNew');
            const openEdit = document.getElementById('btnEdit');
            const closeBtns = [document.getElementById('bookModalClose'), document.getElementById('bookModalCancel')];
            const form = document.getElementById('bookForm');
            const titleEl = document.getElementById('bookModalTitle');
            const saveBtn = document.getElementById('bookModalSave');
            const table = document.getElementById('booksTable');

            // Form fields
            const fldId = document.getElementById('bookId');
            const fldTitle = document.getElementById('bookTitle');
            const fldCopiesAvail = document.getElementById('copiesAvailable');
            const fldTotalCopies = document.getElementById('totalCopies');
            const fldNotes = document.getElementById('notes');

            function populateFromRow(row){
                if(!row) return;
                fldId.value = row.dataset.id || '';
                fldTitle.value = row.dataset.title || '';
                fldCopiesAvail.value = row.dataset.copiesAvailable || '';
                fldTotalCopies.value = row.dataset.totalCopies || '';
                // notes not stored in table currently
            }

            function open(mode){
                titleEl.textContent = mode === 'edit' ? 'Edit Book' : 'Add New Book';
                if(mode === 'new') { form.reset(); fldId.value=''; }
                if(mode === 'edit') {
                    const selected = table.querySelector('tbody .row-select:checked');
                    const row = selected ? selected.closest('tr') : null;
                    form.reset();
                    populateFromRow(row);
                }
                modal.classList.add('show');
                document.body.style.overflow='hidden';
            }
            function close(){
                modal.classList.remove('show');
                document.body.style.overflow='';
            }
            openNew?.addEventListener('click',()=>open('new'));
            openEdit?.addEventListener('click',()=>open('edit'));
            closeBtns.forEach(b=>b?.addEventListener('click',close));
            modal.addEventListener('click',e=>{ if(e.target===modal) close(); });
            saveBtn.addEventListener('click',()=>close());
        })();
    </script>
}